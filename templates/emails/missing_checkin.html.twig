{% extends 'emails/base.html.twig' %}

{% block title %}Missing check-in — {{ employeeName }}{% endblock %}

{% block content %}
  <h1>Missing check-in</h1>
  <p>{{ employeeName }} has not checked in for their shift at {{ workspaceName }}.</p>

  <div class="detail-row">
    <span class="detail-label">Shift</span>
    <span class="detail-value">{{ shiftName }}</span>
  </div>
  <div class="detail-row">
    <span class="detail-label">Started at</span>
    <span class="detail-value">{{ shiftStart }}</span>
  </div>
  <div class="detail-row">
    <span class="detail-label">Expected by</span>
    <span class="detail-value">{{ expectedTime }}</span>
  </div>
{% endblock %}
