<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}DailyBrew{% endblock %}</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      background-color: #FAF7F2;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      color: #2C2420;
      line-height: 1.6;
    }
    .wrapper {
      max-width: 560px;
      margin: 0 auto;
      padding: 40px 20px;
    }
    .logo {
      text-align: center;
      padding-bottom: 24px;
    }
    .logo span {
      font-family: 'Palatino Linotype', 'Book Antiqua', Palatino, Georgia, serif;
      font-size: 22px;
      font-weight: 600;
      color: #6B4226;
    }
    .card {
      background-color: #ffffff;
      border: 1px solid #EBE2D6;
      border-radius: 16px;
      padding: 32px;
    }
    .card h1 {
      font-family: 'Palatino Linotype', 'Book Antiqua', Palatino, Georgia, serif;
      font-size: 20px;
      font-weight: 600;
      color: #2C2420;
      margin: 0 0 8px 0;
    }
    .card p {
      font-size: 15px;
      color: #7C6860;
      margin: 0 0 16px 0;
    }
    .detail-row {
      display: flex;
      justify-content: space-between;
      padding: 10px 0;
      border-bottom: 1px solid #F3EDE3;
      font-size: 14px;
    }
    .detail-row:last-child {
      border-bottom: none;
    }
    .detail-label {
      color: #AE9D95;
    }
    .detail-value {
      color: #2C2420;
      font-weight: 500;
    }
    .badge {
      display: inline-block;
      font-size: 12px;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 99px;
    }
    .badge-green { background-color: rgba(74, 124, 89, 0.1); color: #4A7C59; }
    .badge-amber { background-color: rgba(193, 127, 59, 0.1); color: #C17F3B; }
    .badge-red { background-color: rgba(192, 57, 43, 0.1); color: #C0392B; }
    .badge-blue { background-color: rgba(59, 111, 160, 0.1); color: #3B6FA0; }
    .footer {
      text-align: center;
      padding-top: 24px;
      font-size: 13px;
      color: #AE9D95;
    }
    .stats-grid {
      display: flex;
      gap: 12px;
      margin: 16px 0;
    }
    .stat-box {
      flex: 1;
      text-align: center;
      padding: 12px 8px;
      background-color: #FAF7F2;
      border-radius: 10px;
    }
    .stat-number {
      font-size: 22px;
      font-weight: 700;
      color: #2C2420;
      display: block;
    }
    .stat-label {
      font-size: 12px;
      color: #AE9D95;
      display: block;
      margin-top: 2px;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="logo">
      <span>DailyBrew</span>
    </div>
    <div class="card">
      {% block content %}{% endblock %}
    </div>
    <div class="footer">
      {% block footer %}
        DailyBrew &mdash; Staff attendance tracking for restaurants
      {% endblock %}
    </div>
  </div>
</body>
</html>
