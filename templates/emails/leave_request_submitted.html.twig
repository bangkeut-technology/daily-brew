{% extends 'emails/base.html.twig' %}

{% block title %}New leave request{% endblock %}

{% block content %}
  <h1>New leave request</h1>
  <p>{{ employeeName }} has submitted a leave request in {{ workspaceName }}.</p>

  <div class="detail-row">
    <span class="detail-label">Employee</span>
    <span class="detail-value">{{ employeeName }}</span>
  </div>
  <div class="detail-row">
    <span class="detail-label">Dates</span>
    <span class="detail-value">{{ dates }}</span>
  </div>
  {% if reason %}
  <div class="detail-row">
    <span class="detail-label">Reason</span>
    <span class="detail-value">{{ reason }}</span>
  </div>
  {% endif %}
  <div class="detail-row">
    <span class="detail-label">Status</span>
    <span class="detail-value"><span class="badge badge-amber">Pending</span></span>
  </div>
{% endblock %}
