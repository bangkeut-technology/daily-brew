{% extends 'emails/base.html.twig' %}

{% block title %}Daily summary — {{ workspaceName }}{% endblock %}

{% block content %}
  <h1>Daily summary</h1>
  <p>Here's today's attendance overview for {{ workspaceName }}.</p>

  <div class="stats-grid">
    <div class="stat-box">
      <span class="stat-number">{{ presentCount }}</span>
      <span class="stat-label">Present</span>
    </div>
    <div class="stat-box">
      <span class="stat-number">{{ lateCount }}</span>
      <span class="stat-label">Late</span>
    </div>
    <div class="stat-box">
      <span class="stat-number">{{ onLeaveCount }}</span>
      <span class="stat-label">On leave</span>
    </div>
    <div class="stat-box">
      <span class="stat-number">{{ absentCount }}</span>
      <span class="stat-label">Absent</span>
    </div>
  </div>

  <div class="detail-row">
    <span class="detail-label">Total employees</span>
    <span class="detail-value">{{ totalEmployees }}</span>
  </div>
{% endblock %}
