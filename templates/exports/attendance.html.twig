<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Attendance — {{ workspaceName }} — {{ from }} to {{ to }}</title>
    <style>
        @page { margin: 12mm 8mm; }
        body { font-family: DejaVu Sans, sans-serif; font-size: 8pt; color: #1E1916; }
        h1 { font-family: Palatino, Georgia, serif; font-size: 15pt; margin: 0 0 4px; color: #6B4226; }
        .meta { font-size: 8pt; color: #6B6463; margin-bottom: 10px; }
        table { width: 100%; border-collapse: collapse; table-layout: fixed; }
        th, td { border: 0.5px solid #E5DFD6; text-align: center; vertical-align: middle; overflow: hidden; }
        thead th { background: #EFEAE3; color: #1E1916; font-weight: 600; font-size: 6.5pt; padding: 3px 1px;
                   border-bottom: 1.5px solid #6B4226; }
        th.emp, td.emp { text-align: left; width: 110px; padding: 3px 5px; font-size: 7.5pt; }
        td.cell { font-size: 6.5pt; padding: 2px 1px; line-height: 1.15; }
        td.cell .code { font-weight: 700; }
        td.cell .time { display: block; font-size: 5.5pt; color: #6B6463; font-variant-numeric: tabular-nums; }
        .s-present { background: #EAF3EC; }
        .s-present .code { color: #4A7C59; }
        .s-flag { background: #FBF1E0; }
        .s-flag .code { color: #B26B16; }
        .s-absent { background: #F8E8E6; }
        .s-absent .code { color: #C0392B; }
        .s-leave { background: #E9F0F7; }
        .s-leave .code { color: #3B6FA0; }
        .s-off, .s-closure, .s-voided { background: #F1EEEB; }
        .s-off .code, .s-closure .code, .s-voided .code, .s-untracked .code { color: #6B6463; }
        th.tot, td.tot { width: 26px; font-weight: 700; font-size: 7pt; background: #F6F2EC; }
        thead th.tot { font-size: 6.5pt; }
        .legend { margin-top: 10px; font-size: 7pt; color: #6B6463; }
        .legend b { color: #1E1916; }
        .footer { margin-top: 8px; font-size: 7pt; color: #6B6463; text-align: right; }
    </style>
</head>
<body>
    <h1>Attendance — {{ workspaceName }}</h1>
    <div class="meta">{{ from }} to {{ to }} ({{ timezone }}) · monthly grid</div>

    <table>
        <thead>
            <tr>
                <th class="emp">Employee</th>
                {% for col in columns %}
                    <th>{{ col.weekday }}<br>{{ col.day }}</th>
                {% endfor %}
                <th class="tot">Pre</th>
                <th class="tot">Sch</th>
                <th class="tot">Abs</th>
                <th class="tot">Late</th>
                <th class="tot">Lv</th>
            </tr>
        </thead>
        <tbody>
        {% for row in rows %}
            <tr>
                <td class="emp">{{ row.name }}</td>
                {% for cell in row.cells %}
                    {% if cell is null %}
                        <td class="cell"></td>
                    {% else %}
                        <td class="cell s-{{ cell.status }}">
                            <span class="code">{{ cell.code }}</span>
                            {% if cell.time %}<span class="time">{{ cell.time }}</span>{% endif %}
                        </td>
                    {% endif %}
                {% endfor %}
                <td class="tot">{{ row.totals.present }}</td>
                <td class="tot">{{ row.totals.scheduled }}</td>
                <td class="tot">{{ row.totals.absent }}</td>
                <td class="tot">{{ row.totals.late }}</td>
                <td class="tot">{{ row.totals.leave }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <div class="legend">
        <b>Pre</b> present · <b>Lt</b> late · <b>LfE</b> left early · <b>Abs</b> absent ·
        <b>Lv</b> leave · <b>Off</b> off day · <b>C</b> closed · <b>Vd</b> voided · <b>—</b> not tracked
    </div>
    <div class="footer">Generated {{ generatedAt }} · DailyBrew</div>
</body>
</html>
