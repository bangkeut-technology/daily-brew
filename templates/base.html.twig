<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=5" />
    <title>{% block title %}DailyBrew — Staff Attendance{% endblock %}</title>
    <link rel="icon" type="image/svg+xml" href="{{ asset('favicon.svg') }}" />

    {% block stylesheets %}
        {{ encore_entry_link_tags('daily_brew_application') }}
    {% endblock %}

    {% block javascripts %}
        {{ encore_entry_script_tags('daily_brew_application') }}
        <script type="text/javascript">
            window.__DAILYBREW__ = {
                maxFreeEmployees: {{ maxFreeEmployees }},
                contactEmail: '{{ contactEmail|e('js') }}',
                googleClientId: '{{ googleClientId|e('js') }}',
                appleClientId: '{{ appleClientId|e('js') }}'
            };
        </script>
    {% endblock %}
</head>
<body class="h-full w-full">
    <div id="daily_brew_application" class="h-full w-full"></div>
    {% block body %}{% endblock %}
</body>
</html>
