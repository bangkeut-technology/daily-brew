<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=5" />
    <title>{% block title %}DailyBrew — Staff Attendance Tracking for Restaurants{% endblock %}</title>
    <meta name="description" content="QR check-in, shift tracking, and leave management for restaurants. Free for up to 10 employees." />
    <link rel="canonical" href="https://dailybrew.work/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="DailyBrew" />
    <meta property="og:title" content="DailyBrew — Staff Attendance Tracking for Restaurants" />
    <meta property="og:description" content="QR check-in, shift tracking, and leave management for restaurants. Free for up to 10 employees." />
    <meta property="og:url" content="https://dailybrew.work/" />
    <meta property="og:image" content="https://dailybrew.work/android-chrome-512.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="DailyBrew — Staff Attendance Tracking for Restaurants" />
    <meta name="twitter:description" content="QR check-in, shift tracking, and leave management for restaurants. Free for up to 10 employees." />
    <meta name="twitter:image" content="https://dailybrew.work/android-chrome-512.png" />

    <link rel="icon" type="image/svg+xml" href="{{ asset('favicon.svg') }}" />
    <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('favicon-32.png') }}" />
    <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('favicon-16.png') }}" />
    <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('apple-touch-icon.png') }}" />
    <link rel="manifest" href="{{ asset('manifest.json') }}" />
    <meta name="theme-color" content="#6B4226" />

    {% block stylesheets %}
        {{ encore_entry_link_tags('daily_brew_application') }}
    {% endblock %}

    {% block javascripts %}
        {{ encore_entry_script_tags('daily_brew_application') }}
        <script src="https://cdn.paddle.com/paddle/v2/paddle.js"></script>
        <script type="text/javascript">
            window.__DAILYBREW__ = {
                maxFreeEmployees: {{ maxFreeEmployees }},
                contactEmail: '{{ contactEmail|e('js') }}',
                googleClientId: '{{ googleClientId|e('js') }}',
                appleClientId: '{{ appleClientId|e('js') }}',
                paddleEnvironment: '{{ paddleEnvironment|e('js') }}',
                paddleClientSideToken: '{{ paddleClientSideToken|e('js') }}',
                paddlePriceIdMonthly: '{{ paddlePriceIdEspressoMonthly|e('js') }}',
                paddlePriceIdAnnual: '{{ paddlePriceIdEspressoAnnual|e('js') }}',
                user: {{ user is not null ? user|json_encode|raw : 'null' }}
            };
        </script>
    {% endblock %}
</head>
<body class="h-full w-full">
    <div id="daily_brew_application" class="h-full w-full"></div>
    {% block body %}{% endblock %}
</body>
</html>
