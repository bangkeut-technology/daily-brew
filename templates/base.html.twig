{% set htmlLang = htmlLang|default('en') %}
<!DOCTYPE html>
<html lang="{{ htmlLang|e('html_attr') }}" class="h-full">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=5" />
    {% set metaTitle = metaTitle|default('DailyBrew — Staff Attendance Tracking for Restaurants') %}
    {% set metaDescription = metaDescription|default('QR check-in, shift tracking, and leave management for restaurants. Free for up to 10 employees.') %}
    {% set ogUrl = ogUrl|default('https://dailybrew.work/') %}
    {# Map our two-letter UI locale to og:locale's IETF tag. Single-region only; expand if we add regional variants. #}
    {% set ogLocale = {'en': 'en_US', 'fr': 'fr_FR', 'km': 'km_KH'}[htmlLang]|default('en_US') %}
    <title>{{ metaTitle }}</title>
    <meta name="description" content="{{ metaDescription }}" />
    {% if robots is defined and robots %}
        <meta name="robots" content="{{ robots }}" />
    {% endif %}
    {% if canonicalUrl is defined and canonicalUrl %}
        <link rel="canonical" href="{{ canonicalUrl }}" />
    {% endif %}

    {# hreflang alternates — tells Google this URL is available in multiple languages.
       We use ?lang= variants because the SPA serves all locales from the same path;
       x-default points at the unparameterized URL (English). Empty for non-indexable pages. #}
    {% if hreflangAlternates is defined and hreflangAlternates %}
        {% for code, href in hreflangAlternates %}
            <link rel="alternate" hreflang="{{ code|e('html_attr') }}" href="{{ href|e('html_attr') }}" />
        {% endfor %}
    {% endif %}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="DailyBrew" />
    <meta property="og:locale" content="{{ ogLocale }}" />
    <meta property="og:title" content="{{ metaTitle }}" />
    <meta property="og:description" content="{{ metaDescription }}" />
    <meta property="og:url" content="{{ ogUrl }}" />
    <meta property="og:image" content="https://dailybrew.work/android-chrome-512.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ metaTitle }}" />
    <meta name="twitter:description" content="{{ metaDescription }}" />
    <meta name="twitter:image" content="https://dailybrew.work/android-chrome-512.png" />

    {# Site-wide structured data (Organization + SoftwareApplication). Per-page schema
       (FAQPage, Article, etc.) is appended by individual route templates if/when added. #}
    {% if structuredData is defined and structuredData %}
        <script type="application/ld+json">{{ structuredData|json_encode(constant('JSON_UNESCAPED_SLASHES') b-or constant('JSON_UNESCAPED_UNICODE'))|raw }}</script>
    {% endif %}

    {% if gaMeasurementId is defined and gaMeasurementId is not empty %}
        <script async src="https://www.googletagmanager.com/gtag/js?id={{ gaMeasurementId|e('html_attr') }}"></script>
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', '{{ gaMeasurementId|e('js') }}');
        </script>
    {% endif %}

    <link rel="icon" type="image/svg+xml" href="{{ asset('favicon.svg') }}" />
    <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('favicon-32.png') }}" />
    <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('favicon-16.png') }}" />
    <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('apple-touch-icon.png') }}" />
    <link rel="manifest" href="{{ asset('manifest.json') }}" />
    <meta name="theme-color" content="#6B4226" />

    {% block stylesheets %}
        {{ encore_entry_link_tags('daily_brew_application') }}
    {% endblock %}

    {% block javascripts %}
        {{ encore_entry_script_tags('daily_brew_application') }}
        <script src="https://cdn.paddle.com/paddle/v2/paddle.js"></script>
        <script type="text/javascript">
            window.__DAILYBREW__ = {
                maxFreeEmployees: {{ maxFreeEmployees }},
                contactEmail: '{{ contactEmail|e('js') }}',
                googleClientId: '{{ googleClientId|e('js') }}',
                appleClientId: '{{ appleClientId|e('js') }}',
                paddleEnvironment: '{{ paddleEnvironment|e('js') }}',
                paddleClientSideToken: '{{ paddleClientSideToken|e('js') }}',
                paddlePriceIdEspressoMonthly: '{{ paddlePriceIdEspressoMonthly|e('js') }}',
                paddlePriceIdEspressoAnnual: '{{ paddlePriceIdEspressoAnnual|e('js') }}',
                paddlePriceIdDoubleEspressoMonthly: '{{ paddlePriceIdDoubleEspressoMonthly|e('js') }}',
                paddlePriceIdDoubleEspressoAnnual: '{{ paddlePriceIdDoubleEspressoAnnual|e('js') }}',
                telegramBotUsername: '{{ telegramBotUsername|e('js') }}',
                // Server-detected SEO/UI locale ('en' | 'fr' | 'km'). The SPA's
                // i18next init reads this first so first paint matches what the
                // server rendered in the <html lang> + meta tags. The language
                // switcher still owns subsequent changes (sessionStorage + reload).
                initialLocale: '{{ htmlLang|e('js') }}',
                user: null
            };
        </script>
    {% endblock %}
</head>
<body class="h-full w-full">
    <div id="daily_brew_application" class="h-full w-full"></div>
    {% block body %}{% endblock %}
</body>
</html>
