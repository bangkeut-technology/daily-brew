{
    "compilerOptions": {
        "lib": ["dom", "dom.iterable", "esnext"],
        "typeRoots": ["./node_modules/@types", "./assets/src/types"],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "ignoreDeprecations": "6.0",
        "strictNullChecks": true,
        "noEmit": true,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "target": "ESNext",
        "jsx": "preserve",
        "incremental": true,
        "baseUrl": "./",
        "paths": {
            "@/*": ["./assets/src/*"]
        }
    },
    "include": ["assets/**/*.ts", "assets/**/*.tsx"],
    "exclude": ["node_modules"]
}
