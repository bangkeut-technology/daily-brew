{
    "type": "project",
    "name": "bangkeut-technology/daily-brew",
    "description": "A KPI platform for small businesses",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-bcmath": "*",
        "ext-ctype": "*",
        "ext-fileinfo": "*",
        "ext-gd": "*",
        "ext-iconv": "*",
        "ext-imagick": "*",
        "ext-intl": "*",
        "ext-json": "*",
        "ext-openssl": "*",
        "beberlei/doctrineextensions": "^1.5",
        "doctrine/dbal": "^3.10",
        "doctrine/doctrine-bundle": "^2.18",
        "doctrine/doctrine-migrations-bundle": "^3.7",
        "doctrine/orm": "^3.6",
        "endroid/qr-code": "*",
        "gesdinet/jwt-refresh-token-bundle": "^1.5",
        "guzzlehttp/guzzle": "^7.10",
        "knpuniversity/oauth2-client-bundle": "^2.20",
        "league/oauth2-facebook": "^2.2",
        "league/oauth2-google": "^4.1",
        "league/oauth2-linkedin": "^5.1",
        "lexik/jwt-authentication-bundle": "^3.2",
        "matomo/device-detector": "^6.5",
        "nelmio/api-doc-bundle": "^4.28",
        "nucleos/dompdf-bundle": "^4.5",
        "patrickbussmann/oauth2-apple": "^0.3.0",
        "phpdocumentor/reflection-docblock": "^5.6",
        "phpoffice/phpspreadsheet": "^3.8",
        "phpstan/phpdoc-parser": "^2.3",
        "scheb/2fa-email": "^7.11",
        "stevenmaguire/oauth2-microsoft": "^2.2",
        "symfony/ai-bundle": "*",
        "symfony/ai-store": "^0.1.0",
        "symfony/asset": "7.4.*",
        "symfony/console": "7.4.*",
        "symfony/doctrine-messenger": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/expression-language": "7.4.*",
        "symfony/filesystem": "7.4.*",
        "symfony/flex": "^2.4",
        "symfony/form": "7.4.*",
        "symfony/framework-bundle": "7.4.*",
        "symfony/http-client": "7.4.*",
        "symfony/intl": "7.4.*",
        "symfony/mailer": "7.4.*",
        "symfony/mailgun-mailer": "7.4.*",
        "symfony/mime": "7.4.*",
        "symfony/monolog-bundle": "^3.0",
        "symfony/notifier": "7.4.*",
        "symfony/process": "7.4.*",
        "symfony/property-access": "7.4.*",
        "symfony/property-info": "7.4.*",
        "symfony/rate-limiter": "7.4.*",
        "symfony/requirements-checker": "^2.0",
        "symfony/runtime": "7.4.*",
        "symfony/security-bundle": "7.4.*",
        "symfony/serializer": "7.4.*",
        "symfony/string": "7.4.*",
        "symfony/telegram-notifier": "7.4.*",
        "symfony/translation": "7.4.*",
        "symfony/twig-bundle": "7.4.*",
        "symfony/type-info": "7.4.*",
        "symfony/uid": "7.4.*",
        "symfony/validator": "7.4.*",
        "symfony/web-link": "7.4.*",
        "symfony/webpack-encore-bundle": "^2.1",
        "symfony/workflow": "7.4.*",
        "symfony/yaml": "7.4.*",
        "twig/extra-bundle": "^3.22",
        "twig/twig": "^3.22",
        "ua-parser/uap-php": "^3.10",
        "vich/uploader-bundle": "^2.9"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "phpro/grumphp": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "requirements-checker": "script"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "cs": "php-cs-fixer fix --dry-run --diff",
        "stan": "phpstan analyse",
        "test": "phpunit"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*"
        }
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^8.3",
        "fakerphp/faker": "^1.24",
        "phpunit/phpunit": "^12.3",
        "roave/security-advisories": "dev-latest",
        "symfony/browser-kit": "7.4.*",
        "symfony/css-selector": "7.4.*",
        "symfony/debug-bundle": "7.4.*",
        "symfony/dom-crawler": "7.4.*",
        "symfony/maker-bundle": "^1.62",
        "symfony/phpunit-bridge": "^7.2",
        "symfony/stopwatch": "7.4.*",
        "symfony/web-profiler-bundle": "7.4.*"
    }
}
